# VLM backend: openai | anthropic | local | mock | off
VLM_BACKEND=off

# API keys (required when using corresponding VLM backend)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OCR language for PaddleOCR fallback (e.g. ru, en, rus+eng)
OCR_LANG=ru

# VLM request timeout in seconds
VLM_TIMEOUT_SEC=30

# OpenAI model for vision tasks
OPENAI_VLM_MODEL=gpt-4o-mini

# Anthropic model for vision tasks
ANTHROPIC_VLM_MODEL=claude-3-5-sonnet-20241022

# GROBID server for academic PDF metadata (optional)
GROBID_SERVER=http://localhost:8070
